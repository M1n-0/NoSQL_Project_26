# Copier ce fichier en ".env" et compléter les valeurs réelles
# (ce fichier .env.example peut rester versionné, jamais le .env)

PORT=3000
JWT_SECRET=changeme

# --- SQL (MariaDB) ---
SQL_HOST=localhost
SQL_PORT=3306
SQL_USER=fablab_app
SQL_PASSWORD=fablab_app_pass
SQL_DATABASE=fablab

# --- MongoDB ---
MONGO_URI=mongodb://root:rootpass@localhost:27017/?authSource=admin
MONGO_DATABASE=fablab

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=fablab_redis_pass

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fablab_neo4j_pass
