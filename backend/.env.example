# Copier ce fichier en ".env" et compléter les valeurs réelles
# (ce fichier .env.example peut rester versionné, jamais le .env)

PORT=3000
JWT_SECRET=changeme

# --- SQL (PostgreSQL) ---
SQL_HOST=localhost
SQL_PORT=5432
SQL_USER=fablab
SQL_PASSWORD=changeme
SQL_DATABASE=fablab_manager

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=fablab_manager

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
